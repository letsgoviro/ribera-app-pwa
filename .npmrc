# Enforce Node version matches .nvmrc
engine-strict=true

# Never install packages globally from within this project
global-bin-dir=.pnpm-bin

# Keep all binaries local — never rely on global installs
prefer-frozen-lockfile=false
strict-peer-dependencies=false
shamefully-hoist=false

# pnpm virtual store inside project
virtual-store-dir=node_modules/.pnpm

# Run scripts with local node_modules/.bin on PATH (isolates from global)
shell-emulator=true
