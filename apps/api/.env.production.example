# ─────────────────────────────────────────────────────────────────────────────
# Ribera API — Production Environment (DigitalOcean)
#
# Copy relevant vars to the DO App Platform dashboard:
#   App → Settings → App-Level Environment Variables
#   Mark sensitive values as "Encrypted" (type: SECRET in app.yaml)
#
# DATABASE_URL and DIRECT_URL are auto-injected by DO when the 'databases'
# component is configured in .do/app.yaml. You do NOT set these manually.
# ─────────────────────────────────────────────────────────────────────────────

NODE_ENV=production
PORT=3001
PUBLIC_WEB_URL=https://ribera.app

# ── DigitalOcean Managed PostgreSQL ──────────────────────────────────────────
# These are auto-provided by DO App Platform when a database is linked.
# Format: postgresql://doadmin:{password}@{host}:{port}/defaultdb?sslmode=require
#
# For the pooled connection (PgBouncer, port 25060):
DATABASE_URL=postgresql://doadmin:{password}@{host}:25060/defaultdb?pgbouncer=true&sslmode=require&connection_limit=10&pool_timeout=20
#
# For direct connections (Prisma migrations, port 5432):
DIRECT_URL=postgresql://doadmin:{password}@{host}:5432/defaultdb?sslmode=require

# ── Supabase — AUTH ONLY (no DB access) ──────────────────────────────────────
# Supabase PostgreSQL is no longer used as the application database.
# These keys are used ONLY for: JWT verification, Google OAuth, user management API.
SUPABASE_URL=https://spzpfjwkohsufvrplaom.supabase.co
SUPABASE_ANON_KEY=sb_publishable_L3fEFEdmRG15zxhVRIyQwg_vJCJVWuJ
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...  # from Supabase dashboard

# ── Supabase Storage — still used for image uploads (free 1GB) ───────────────
SUPABASE_STORAGE_BUCKET=ribera-assets

# ── DPO Pay ───────────────────────────────────────────────────────────────────
DPO_COMPANY_TOKEN=D1A1004C-AA72-4670-AF62-F651621E7D31
DPO_COMPANY_ID=D1A1004C-AA72-4670-AF62-F651621E7D31
DPO_SERVICE_TYPE=110331
DPO_CURRENCY=TZS
DPO_ENVIRONMENT=live
DPO_API_URL=https://secure.3gdirectpay.com/API/v6/
DPO_PAYMENT_URL=https://secure.3gdirectpay.com/payv2.php

# ── Brevo (email + SMS) ───────────────────────────────────────────────────────
BREVO_API_KEY=xkeysib-...
BREVO_SMTP_HOST=smtp-relay.brevo.com
BREVO_SMTP_PORT=587
BREVO_SMTP_USER=...@smtp-brevo.com
BREVO_SMTP_PASS=xsmtpsib-...
FROM_EMAIL=support@riberaapp.me
FROM_NAME=Ribera
# TEST_EMAIL_OVERRIDE — DO NOT SET IN PRODUCTION

# ── OAuth ────────────────────────────────────────────────────────────────────
OAUTH_CLIENT_ID=18d18fef-0f4d-46b7-b630-b911e44e4b1b
OAUTH_CLIENT_SECRET=...
OAUTH_REDIRECT_URL=https://ribera.app/auth/callback

# ── Security ──────────────────────────────────────────────────────────────────
QR_JWT_SECRET=...  # generate: openssl rand -hex 32
WEBHOOK_SECRET=...  # generate: openssl rand -hex 24
ADMIN_EMAIL_DOMAIN=ribera.app

# ── Feature flags ─────────────────────────────────────────────────────────────
SERVICE_FEE_PERCENT=5
ENABLE_BOOST=true
