# Server
NODE_ENV=development
PORT=3001
API_URL=http://localhost:3001

# Database (DigitalOcean Managed PostgreSQL)
DATABASE_URL=postgresql://user:password@host:25060/ribera?sslmode=require

# Supabase (Auth only)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_JWT_SECRET=your-jwt-secret

# DPO Pay
DPO_COMPANY_TOKEN=your-company-token
DPO_SERVICE_TYPE=your-service-type
DPO_CURRENCY=TZS
DPO_ENVIRONMENT=sandbox

# Brevo (Email)
BREVO_API_KEY=your-brevo-api-key
FROM_EMAIL=tickets@ribera.app
FROM_NAME=Ribera

# DigitalOcean Spaces (Storage)
DO_SPACES_KEY=your-spaces-key
DO_SPACES_SECRET=your-spaces-secret
DO_SPACES_ENDPOINT=https://nyc3.digitaloceanspaces.com
DO_SPACES_BUCKET=ribera-assets
DO_SPACES_CDN_URL=https://ribera-assets.nyc3.cdn.digitaloceanspaces.com

# Security
QR_JWT_SECRET=super-secret-32-char-string-here
ADMIN_EMAIL_DOMAIN=ribera.app

# Feature flags
SERVICE_FEE_PERCENT=5
ENABLE_BOOST=true
